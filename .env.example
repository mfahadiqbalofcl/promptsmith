# ── All optional. PROMPTSMITH runs fully free with NONE of these set. ─────────

# ── AI Boost + AI-distill: multi-provider failover chain ──────────────────────
# Set any of these and AI features turn on. The chain is tried in order; when one
# rate-limits or errors, the next takes over automatically (24/7 resilience).
# Groq and OpenRouter both have free tiers and are the recommended pair.
GROQ_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Optional model overrides (sensible free-tier defaults are built in).
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
PROMPTSMITH_BOOST_MODEL=claude-sonnet-4-6

# Failover order (comma-separated). Default: groq,openrouter,anthropic
PROMPTSMITH_AI_ORDER=groq,openrouter,anthropic

# ── Public-instance safety ────────────────────────────────────────────────────
# Set on a PUBLIC deploy to lock store-mutating endpoints (add/mute/delete lessons,
# AI-distill) behind an `x-promptsmith-admin` header. AI Boost stays open for users.
PROMPTSMITH_ADMIN_TOKEN=

# Absolute base URL of your deployment (OG/social meta + OpenRouter attribution).
NEXT_PUBLIC_SITE_URL=https://promptsmith.vercel.app

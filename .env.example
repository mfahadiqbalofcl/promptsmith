# ── All optional. PROMPTSMITH runs fully free with NONE of these set. ─────────

# Enables the optional "AI Boost" + "AI-distill" features (Claude). Without it,
# both degrade gracefully and the deterministic engine works exactly the same.
ANTHROPIC_API_KEY=

# Model used for the Boost / distill passes.
PROMPTSMITH_BOOST_MODEL=claude-sonnet-4-6

# Set this on a PUBLIC instance to lock the store-mutating + paid endpoints
# (add/mute/delete lessons, AI-distill). Requests must then send a matching
# `x-promptsmith-admin` header. Leave empty for local/self-host (fully open).
# IMPORTANT: if you set ANTHROPIC_API_KEY on a public deploy, set this too,
# or anyone can run up your API bill.
PROMPTSMITH_ADMIN_TOKEN=

# Absolute base URL of your deployment (used for OG/social meta + canonical).
NEXT_PUBLIC_SITE_URL=https://promptsmith.vercel.app
